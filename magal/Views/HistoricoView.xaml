<UserControl x:Class="magal.Views.HistoricoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Language="pt-BR"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F0F4FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="Primary" Color="#14607D"/>
        <SolidColorBrush x:Key="TextMuted" Color="#64748B"/>
        <SolidColorBrush x:Key="TextHint" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Border" Color="#E2E8F0"/>
        <SolidColorBrush x:Key="Verde" Color="#009140"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,8"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F4A61"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource Primary}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="60" Margin="0,0,0,10">
            <TextBlock Text="Histórico de Orçamentos"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource Primary}"
                       VerticalAlignment="Center"/>

            <Button Content="ATUALIZAR"
                    Command="{Binding AtualizarCommand}"
                    Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="BUSCAR POR CLIENTE OU PLACA" FontSize="11" FontWeight="Bold" Foreground="{StaticResource Primary}" Margin="0,0,0,4"/>
            <Border BorderThickness="1.5" BorderBrush="{StaticResource Border}" Height="42" Background="White">
                <Grid>
                    <TextBox Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Padding="12,0,40,0"
                             FontSize="14"
                             Background="Transparent"
                             BorderThickness="0"/>
                    <TextBlock Text="🔍" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource TextHint}" IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="2" Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="{StaticResource Border}" Padding="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid Grid.Row="0"
                          ItemsSource="{Binding OrcamentosView}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          CanUserResizeColumns="False" CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="{StaticResource Border}"
                          HeadersVisibility="Column"
                          RowHeight="56" SelectionMode="Single"
                          FontSize="14">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATA" Binding="{Binding DataCriacao, StringFormat=dd/MM/yyyy}" Width="110" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="CLIENTE" Binding="{Binding ClienteNome}" Width="*" FontSize="15" FontWeight="SemiBold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="TELEFONE" Binding="{Binding ClienteTelefone}" Width="150"/>
                        <DataGridTextColumn Header="VEÍCULO" Binding="{Binding VeiculoModelo}" Width="150" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="PLACA" Binding="{Binding VeiculoPlaca}" Width="110" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="VALOR" Binding="{Binding ValorTotal, StringFormat=C}" Width="140">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="Foreground" Value="{StaticResource Verde}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Setter Property="Padding" Value="0,0,20,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="AÇÕES" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Reabrir"
                                            Command="{Binding DataContext.ReabrirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource LinkBtn}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Background="#F8FAFC" BorderThickness="0,1,0,0" BorderBrush="#F1F5F9" CornerRadius="0,0,16,16" Padding="20,12">
                    <TextBlock Text="{Binding OrcamentosView.Count, StringFormat='{}{0} orçamentos listados'}"
                               FontSize="12" Foreground="{StaticResource TextHint}" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
