<UserControl x:Class="magal.Views.HistoricoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             Language="pt-BR"
             d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F0F4FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AzulAero"        Color="#131C49"/>
        <SolidColorBrush x:Key="AeroAccent"      Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroDanger"      Color="#EF4444"/>
        <SolidColorBrush x:Key="AeroTextMuted"   Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint"    Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder"      Color="#E2E8F0"/>
        <SolidColorBrush x:Key="VerdeAero"       Color="#009140"/>

        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AzulAero}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="8" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1E3A8A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LinkBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource AeroAccent}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="80" Margin="0,0,0,10">
            <TextBlock Text="Histórico de Orçamentos"
                       FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource AzulAero}"
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Command="{Binding AtualizarCommand}"
                        Style="{StaticResource PrimaryBtn}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE72C;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="ATUALIZAR LISTA"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,25">
            <Border Background="White" CornerRadius="12" Margin="0,0,10,0" Padding="20,15"
                    BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                <StackPanel>
                    <TextBlock Text="ORÇAMENTOS LISTADOS" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding QuantidadeOrcamentos}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource AzulAero}"/>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource AzulAero}" CornerRadius="12" Margin="5,0" Padding="20,15">
                <StackPanel>
                    <TextBlock Text="VALOR TOTAL" FontSize="10" FontWeight="Bold" Foreground="#93C5FD" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding ValorTotal}" FontSize="24" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Margin="10,0,0,0" Padding="20,15"
                    BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                <StackPanel>
                    <TextBlock Text="TICKET MÉDIO" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AeroTextHint}" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding TicketMedio}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource VerdeAero}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="FILTRE POR ( CLIENTE OU PLACA )" FontSize="11" FontWeight="Bold" Foreground="{StaticResource AzulAero}" Margin="0,0,0,4"/>

            <Border BorderThickness="1.5" Height="42" Background="White">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <TextBox Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                             VerticalContentAlignment="Center"
                             Padding="12,0,40,0"
                             FontSize="14"
                             Background="Transparent"
                             BorderThickness="0"/>

                    <TextBlock Text="🔍" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="{StaticResource AeroTextHint}" IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Background="White" CornerRadius="16" BorderThickness="1" BorderBrush="{StaticResource AeroBorder}" Padding="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="meuDataGrid"
                          ItemsSource="{Binding OrcamentosView}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          Background="Transparent" BorderThickness="0"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="False"
                          CanUserReorderColumns="False"
                          GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F1F5F9"
                          HeadersVisibility="Column"
                          RowHeight="60" SelectionMode="Single"
                          FontSize="14">

                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F8FAFC"/>
                            <Setter Property="Foreground" Value="{StaticResource AeroTextMuted}"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Padding" Value="15,12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
                        </Style>

                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="15,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#EFF6FF"/>
                                    <Setter Property="Foreground" Value="{StaticResource AzulAero}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#F1F5F9"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATA"
                                            Binding="{Binding DataCriacao, StringFormat=dd/MM/yyyy}"
                                            Width="110"
                                            FontSize="14"
                                            FontWeight="SemiBold" />

                        <DataGridTextColumn Header="CLIENTE"
                                            Binding="{Binding ClienteNome}"
                                            Width="*"
                                            FontSize="15"
                                            FontWeight="SemiBold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="10,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Header="TELEFONE"
                                            Binding="{Binding ClienteTelefone}"
                                            Width="150"
                                            FontWeight="SemiBold"
                                            FontSize="14" />

                        <DataGridTextColumn Header="VEÍCULO"
                                            Binding="{Binding VeiculoModelo}"
                                            Width="150"
                                            FontWeight="SemiBold"
                                            FontSize="14" />

                        <DataGridTextColumn Header="PLACA"
                                            Binding="{Binding VeiculoPlaca}"
                                            Width="110"
                                            FontWeight="SemiBold"
                                            FontSize="14" />

                        <DataGridTextColumn Header="VALOR"
                                            Binding="{Binding ValorTotal, StringFormat='{}{0:C}', ConverterCulture=pt-BR}"
                                            Width="150"
                                            FontSize="16"  FontWeight="Bold">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Foreground" Value="{StaticResource VerdeAero}"/>
                                    <Setter Property="Padding" Value="0,0,20,0"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="AÇÕES" Width="110">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Reabrir"
                                            Command="{Binding DataContext.ReabrirCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource LinkBtn}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Background="#F8FAFC" BorderThickness="0,1,0,0" BorderBrush="#F1F5F9" CornerRadius="0,0,16,16" Padding="20,12">
                    <TextBlock Text="{Binding OrcamentosView.Count, StringFormat='{}{0} orçamentos listados'}"
                               FontSize="12" Foreground="{StaticResource AeroTextHint}" VerticalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="0" Grid.RowSpan="2"
                      x:Name="LoadingOverlay"
                      Background="#CCFFFFFF"
                      Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ProgressBar IsIndeterminate="True"
                                     Width="200"
                                     Height="6"
                                     Foreground="{StaticResource AzulAero}"
                                     Background="#E2E8F0"
                                     BorderThickness="0"/>
                        <TextBlock Text="Carregando..."
                                   Margin="0,12,0,0"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AzulAero}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>