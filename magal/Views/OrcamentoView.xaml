<UserControl x:Class="magal.Views.OrcamentoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
    d:DesignHeight="900" d:DesignWidth="1200"
             Background="#F0F4FA">

    <UserControl.Resources>
        <SolidColorBrush x:Key="AeroPrimary"    Color="#1E3A8A"/>
        <SolidColorBrush x:Key="AeroAccent"     Color="#3B82F6"/>
        <SolidColorBrush x:Key="AeroDanger"     Color="#EF4444"/>
        <SolidColorBrush x:Key="AeroTextDark"   Color="#0F172A"/>
        <SolidColorBrush x:Key="AeroTextMuted"  Color="#64748B"/>
        <SolidColorBrush x:Key="AeroTextHint"   Color="#94A3B8"/>
        <SolidColorBrush x:Key="AeroBorder"     Color="#E2E8F0"/>
        <SolidColorBrush x:Key="BorderLight"    Color="#E2E8F0"/>
        <SolidColorBrush x:Key="AeroCardBg"     Color="#F8FAFC"/>
        <SolidColorBrush x:Key="AeroCardBorder" Color="#E8EEF8"/>
        <SolidColorBrush x:Key="AeroPillBg"     Color="#EFF6FF"/>
        <SolidColorBrush x:Key="AeroPillFg"     Color="#1D4ED8"/>
        <SolidColorBrush x:Key="AzulAero" Color="#131C49"/>
        <SolidColorBrush x:Key="CinzaAero" Color="#ACACAC"/>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AeroPrimary}"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="14,7">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1e40af"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="#94A3B8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconDeleteBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"      Value="#CBD5E1"/>
            <Setter Property="FontWeight"      Value="Bold"/>
            <Setter Property="FontSize"        Value="14"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Width"           Value="28"/>
            <Setter Property="Height"          Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#FEE2E2"/>
                                <Setter Property="Foreground" Value="{StaticResource AeroDanger}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding"          Value="10,8"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="BorderBrush"      Value="{StaticResource AeroBorder}"/>
            <Setter Property="Background"       Value="White"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="Foreground"       Value="{StaticResource AeroTextDark}"/>
        </Style>

        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background"     Value="{StaticResource AeroCardBg}"/>
            <Setter Property="BorderBrush"    Value="{StaticResource AeroCardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"   Value="12"/>
            <Setter Property="Padding"        Value="16,14"/>
            <Setter Property="Margin"         Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#93C5FD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="HoverFieldBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource AeroBorder}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="32,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Height="80" Margin="0,0,0,10">
            <TextBlock Text="Orçamento"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="{StaticResource AzulAero}"
                   VerticalAlignment="Center"/>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- CLIENTE E VEÍCULO -->
                <Border Background="White" CornerRadius="16" Margin="0,0,0,16"
                    BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">

                    <StackPanel>
                        <Grid Margin="20,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AeroPrimary}" CornerRadius="6"
                        Width="24" Height="24" Margin="0,0,10,0">
                                    <TextBlock Text="i" Foreground="White" FontSize="14"
                               FontWeight="Bold" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="DADOS DO CLIENTE E DO VEÍCULO" FontSize="12"
                           FontWeight="Bold" Foreground="{StaticResource AzulAero}"
                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9"/>

                        <Grid Margin="20,20,20,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="NOME DO CLIENTE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,-4,0,6" />

                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.ClienteNome, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Padding="10,0"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="TELEFONE" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,-4,0,6"/>

                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.ClienteTelefone, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold"
                                        BorderThickness="0"
                                        Padding="10,0"
                                        VerticalContentAlignment="Center"
                                        Background="Transparent"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="20,10,20,25">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1.2*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="0.7*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="MARCA" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.VeiculoMarca, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,15,0">
                                <TextBlock Text="MODELO" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.VeiculoModelo, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="0,0,15,0">
                                <TextBlock Text="PLACA" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.VeiculoPlaca, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"
                                        CharacterCasing="Upper"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="0,0,15,0">
                                <TextBlock Text="COR" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.VeiculoCor, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="ANO" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.VeiculoAno, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"
                                        PreviewTextInput="ValidarEntradaSemNegativo"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- PEÇAS E SERVIÇOS -->
                <Border Background="White" CornerRadius="16" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AeroPrimary}" CornerRadius="6"
                                        Width="24" Height="24" Margin="0,0,10,0">
                                    <TextBlock Text="1" Foreground="White" FontSize="11"
                                               FontWeight="Bold" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Text="PEÇAS E SERVIÇOS" FontSize="12"
                                           FontWeight="Bold" Foreground="{StaticResource AzulAero}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9"/>

                        <Grid Margin="20,16,20,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="DESCRIÇÃO" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding NovaDescricaoItem, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AeroTextDark}"
                                        Background="Transparent" BorderThickness="0" Padding="8,0"
                                        VerticalContentAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="VALOR (R$)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" HorizontalAlignment="Right" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding NovoValorItem, UpdateSourceTrigger=PropertyChanged, StringFormat='{}{0:0.00}'}"
                                        FontSize="15" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}"
                                        Background="Transparent" BorderThickness="0"
                                        HorizontalContentAlignment="Right" VerticalContentAlignment="Center" Padding="8,0"
                                        PreviewTextInput="ValidarEntradaSemNegativo"/>
                                </Border>
                            </StackPanel>

                            <Button Grid.Column="4" Content="+ ADICIONAR ITEM"
                                    Command="{Binding AdicionarItemCommand}"
                                    Style="{StaticResource PrimaryBtn}"
                                    Height="40" VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding ItensOrcamento}" Margin="20,14,20,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource TaskCard}" Margin="0,0,0,10" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Descricao}"
                                                       FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{StaticResource AeroTextDark}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="1" Text="{Binding ValorUnitario, StringFormat=C}"
                                                       FontSize="16" FontWeight="Bold"
                                                       Foreground="{StaticResource AeroTextDark}"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"/>

                                            <Button Grid.Column="2" Content="✕"
                                                Command="{Binding DataContext.DeletarItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource IconDeleteBtn}"
                                                VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#F8FAFC" BorderThickness="0,1,0,0" BorderBrush="#F1F5F9" CornerRadius="0,0,16,16" Padding="20,12">
                            <TextBlock Text="{Binding ItensOrcamento.Count, StringFormat='{}{0} itens adicionados'}" FontSize="12" Foreground="{StaticResource AeroTextHint}" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- GARANTIA E OBSERVAÇÕES -->
                <Border Background="White" CornerRadius="16" Margin="0,0,0,16"
                        BorderThickness="1" BorderBrush="{StaticResource AeroBorder}">
                    <StackPanel>
                        <Grid Margin="20,16">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Background="{StaticResource AeroPrimary}" CornerRadius="6" Width="24" Height="24" Margin="0,0,10,0">
                                    <TextBlock Text="2" Foreground="White" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="GARANTIA E OBSERVAÇÕES" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AzulAero}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="#F1F5F9"/>

                        <Grid Margin="20,20,20,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="GARANTIA (DIAS)" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Height="40" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.GarantiaDias, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,0"
                                        VerticalContentAlignment="Center" Background="Transparent"
                                        PreviewTextInput="ValidarEntradaSemNegativo"/>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="OBSERVAÇÕES" FontSize="12" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" Margin="0,0,0,6"/>
                                <Border BorderThickness="1.5" Background="Transparent" Style="{StaticResource HoverFieldBorder}">
                                    <TextBox Text="{Binding OrcamentoAtual.Observacoes, UpdateSourceTrigger=PropertyChanged}"
                                        FontWeight="SemiBold" BorderThickness="0" Padding="10,8"
                                        AcceptsReturn="True" TextWrapping="Wrap" Height="70"
                                        VerticalScrollBarVisibility="Auto" Background="Transparent"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                <StackPanel VerticalAlignment="Center" Margin="0,0,28,0">
                    <TextBlock Text="TOTAL DO ORÇAMENTO" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AeroTextDark}" HorizontalAlignment="Right" Margin="0,0,0,2"/>
                    <TextBlock Text="{Binding OrcamentoAtual.ValorTotal, StringFormat=C}" FontSize="36" FontWeight="Black" Foreground="{StaticResource AeroPrimary}" HorizontalAlignment="Right"/>
                </StackPanel>

                <Button Content="SALVAR ORÇAMENTO"
                        Command="{Binding SalvarOrcamentoCommand}"
                        IsEnabled="{Binding BotaoAtivo}"
                        Style="{StaticResource PrimaryBtn}"
                        Width="220" Height="54" FontSize="13" Margin="0,0,12,0"/>

                <Button Content="GERAR PDF"
                        Command="{Binding GerarPdfCommand}"
                        IsEnabled="{Binding BotaoAtivo}"
                        Style="{StaticResource PrimaryBtn}"
                        Width="180" Height="54" FontSize="13"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="LoadingOverlay"
      Background="#CCFFFFFF"
      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
      Grid.Row="0"
      Grid.RowSpan="99"
      Grid.Column="0"
      Grid.ColumnSpan="99"
      Panel.ZIndex="99999">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True"
                     Width="200"
                     Height="6"
                     Foreground="{StaticResource AzulAero}"
                     Background="#E2E8F0"
                     BorderThickness="0"/>
                <TextBlock Text="Processando..."
                   Margin="0,12,0,0"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource AzulAero}"
                   HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>